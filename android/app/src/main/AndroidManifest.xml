<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="com.android.alarm.permission.SET_ALARM" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Package Visibility (Android 11+): без этого getLaunchIntentForPackage всегда null -->
    <queries>
        <package android:name="org.telegram.messenger" />
        <package android:name="com.whatsapp" />
        <package android:name="com.vkontakte.android" />
        <package android:name="com.google.android.youtube" />
        <package android:name="com.spotify.music" />
        <package android:name="ru.yandex.yandexmaps" />
        <package android:name="com.instagram.android" />
        <package android:name="com.zhiliaoapp.musically" />
        <package android:name="ru.vtb24.mobilebanking.android" />
        <package android:name="ru.sberbankmobile" />
        <package android:name="com.idamob.tinkoff.android" />
        <!-- Навигация -->
        <package android:name="ru.yandex.yandexnavi" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VTBVita"
        android:usesCleartextTraffic="true"
        tools:targetApi="28">

        <!-- Launcher activity — placeholder для разработки -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.VTBVita">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Верификация номера телефона (первый запуск) -->
        <activity
            android:name=".PhoneVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita" />

        <!-- Выбор PIN и вход в профиль -->
        <activity
            android:name=".PinEntryActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita" />

        <!-- Mock-экран банковского приложения -->
        <activity
            android:name=".MockBankActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita" />

        <!-- Экран ввода параметров (Перевод / Пополнение) -->
        <activity
            android:name=".InputActivity"
            android:exported="false"
            android:taskAffinity=""
            android:theme="@style/Theme.VTBVita.BottomSheet" />

        <!-- Модал подтверждения операции (BottomSheet-стиль) -->
        <activity
            android:name=".ConfirmActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita.BottomSheet" />

        <!-- Экран балансов (BottomSheet-стиль) -->
        <activity
            android:name=".BalanceActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita.BottomSheet" />

        <!-- Выбор контакта для перевода (BottomSheet-стиль) -->
        <activity
            android:name=".ContactPickerActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita.BottomSheet" />

        <!-- Ввод параметров пополнения телефона (BottomSheet-стиль) -->
        <activity
            android:name=".TopupInputActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita.BottomSheet" />

        <!-- Шаг 2 флоу перевода: детали (сумма, банк, счёт) -->
        <activity
            android:name=".TransferDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita.BottomSheet" />

        <!-- Выбор из нескольких кандидатов (NLP нашёл 2+ совпадений) -->
        <activity
            android:name=".ContactDisambiguationActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita.BottomSheet" />

        <!-- Голосовая запись из виджета (Foreground Service) -->
        <service
            android:name=".VoiceRecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- AppWidget Provider -->
        <receiver
            android:name=".VitaWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/vita_widget_info" />
        </receiver>

    </application>

</manifest>
