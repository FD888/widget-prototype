<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VTBVita"
        android:usesCleartextTraffic="true"
        tools:targetApi="28">

        <!-- Launcher activity — placeholder для разработки -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.VTBVita">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Экран ввода параметров (Перевод / Пополнение) -->
        <activity
            android:name=".InputActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita" />

        <!-- Модал подтверждения операции (BottomSheet-стиль) -->
        <activity
            android:name=".ConfirmActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita.BottomSheet" />

        <!-- Экран балансов (BottomSheet-стиль) -->
        <activity
            android:name=".BalanceActivity"
            android:exported="false"
            android:theme="@style/Theme.VTBVita.BottomSheet" />

        <!-- AppWidget Provider -->
        <receiver
            android:name=".PulseWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/pulse_widget_info" />
        </receiver>

    </application>

</manifest>
