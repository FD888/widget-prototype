<?xml version="1.0" encoding="utf-8"?>
<!-- clipChildren=false позволяет кольцам выступать за 64dp капсулы -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Фон капсулы: OmegaSurface + brand stroke 2dp -->
    <ImageView
        android:id="@+id/capsule_bg"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="center_vertical"
        android:scaleType="fitXY"
        android:src="@drawable/widget_pill_bg" />

    <LinearLayout
        android:id="@+id/capsule"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <!-- ── IDLE ─────────────────────────────────────────── -->

        <TextView
            android:id="@+id/tv_prompt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:alpha="0.80"
android:text="@string/widget_prompt"
            android:textColor="#FFFFFFFF"
            android:textSize="17sp" />

        <!-- ── SUCCESS — чекмарк ─────────────────────────────────── -->

        <ImageView
            android:id="@+id/iv_status_check"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="@string/a11y_widget_success"
            android:src="@drawable/ic_success_check"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- ── RECORDING — левая кнопка отмены ──────────────── -->

        <ImageView
            android:id="@+id/btn_cancel_rec"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/stop_bg"
            android:contentDescription="@string/a11y_widget_cancel_rec"
            android:padding="10dp"
            android:src="@drawable/ic_cross_widget"
            android:visibility="gone" />

        <!-- ── PREPARING — спиннер ───────────────────────────── -->

        <ProgressBar
            android:id="@+id/pb_preparing"
            style="?android:attr/progressBarStyle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/a11y_widget_preparing"
            android:importantForAccessibility="yes"
            android:indeterminate="true"
            android:indeterminateTint="#FFFFFFFF"
            android:visibility="gone" />

        <!-- ── PREPARING + RECORDING — текст ─────────────────── -->

        <TextView
            android:id="@+id/tv_recording_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:alpha="1.0"
            android:ellipsize="end"
android:maxLines="2"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:visibility="gone" />

        <!-- ── IDLE — кнопка микрофона ───────────────────────── -->

        <ImageView
            android:id="@+id/btn_mic"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/mic_bg"
            android:contentDescription="@string/a11y_widget_mic"
            android:padding="10dp"
            android:src="@drawable/ic_mic" />

        <!-- ── PREPARING — кнопка отмены (справа) ────────────── -->

        <ImageView
            android:id="@+id/btn_stop"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/stop_bg"
            android:contentDescription="@string/a11y_widget_stop"
            android:padding="11dp"
            android:src="@drawable/ic_cross_widget"
            android:visibility="gone" />

        <!-- ── RECORDING — контейнер с кольцами + кнопка ✓ ─── -->
        <!-- 80dp×80dp: переполняет 72dp-капсулу на 4dp сверху/снизу
             clipChildren=false позволяет кольцам быть видимыми снаружи -->

        <FrameLayout
            android:id="@+id/fl_recording_submit"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="6dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone">

            <!-- Кольцо 1 — исходный scale=0, растёт к 1 -->
            <ImageView
                android:id="@+id/ring1"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:scaleX="0"
                android:scaleY="0"
                android:src="@drawable/ripple_ring" />

            <!-- Кольцо 2 — сдвиг фазы 1/3 -->
            <ImageView
                android:id="@+id/ring2"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:scaleX="0"
                android:scaleY="0"
                android:src="@drawable/ripple_ring" />

            <!-- Кольцо 3 — сдвиг фазы 2/3 -->
            <ImageView
                android:id="@+id/ring3"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:scaleX="0"
                android:scaleY="0"
                android:src="@drawable/ripple_ring" />

            <!-- Кнопка ✓ в центре -->
            <ImageView
                android:id="@+id/btn_submit"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@drawable/submit_bg"
                android:contentDescription="@string/a11y_widget_submit"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_widget" />

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
