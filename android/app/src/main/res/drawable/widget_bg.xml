<?xml version="1.0" encoding="utf-8"?>
<!--
    VTB Vita Widget Background — радиальный spotlight, как на главной странице ВТБ Онлайн
    Яркое синее-фиолетовое пятно (верхний левый угол) → тёмно-синий (края)
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="32dp" />
    <gradient
        android:type="radial"
        android:startColor="@color/widget_gradient_start"
        android:centerColor="@color/widget_gradient_mid"
        android:endColor="@color/widget_gradient_end"
        android:gradientRadius="300dp"
        android:centerX="0.2"
        android:centerY="0.0" />
</shape>
